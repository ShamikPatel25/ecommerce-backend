openapi: 3.0.3
info:
  title: Multi-Tenant E-commerce API
  version: 1.0.0
paths:
  /api/auth/login/:
    post:
      operationId: auth_login_create
      description: Authenticate user with email and password. Returns JWT tokens.
      summary: Login user
      tags:
      - Authentication
      requestBody:
        content:
          application/json:
            schema:
              type: object
              properties:
                email:
                  type: string
                  format: email
                password:
                  type: string
                  format: password
              required:
              - email
              - password
      security:
      - jwtAuth: []
      - Bearer: []
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                type: object
                properties:
                  user:
                    type: object
                  tokens:
                    type: object
                    properties:
                      access:
                        type: string
                      refresh:
                        type: string
                  message:
                    type: string
          description: ''
        '401':
          content:
            application/json:
              schema:
                description: Invalid credentials
          description: ''
  /api/auth/profile/:
    get:
      operationId: auth_profile_retrieve
      description: Returns the authenticated user's profile information
      summary: Get current user profile
      tags:
      - Authentication
      security:
      - jwtAuth: []
      - Bearer: []
      responses:
        '200':
          description: No response body
  /api/auth/register/:
    post:
      operationId: auth_register_create
      description: |-
        Register a new user account

        Creates a new user and returns JWT tokens for immediate authentication.
      tags:
      - Authentication
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/UserRegistrationRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/UserRegistrationRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/UserRegistrationRequest'
        required: true
      security:
      - jwtAuth: []
      - Bearer: []
      - {}
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/UserRegistration'
          description: ''
  /api/auth/token/refresh/:
    post:
      operationId: auth_token_refresh_create
      description: |-
        Takes a refresh type JSON web token and returns an access type JSON web
        token if the refresh token is valid.
      tags:
      - auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/TokenRefreshRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/TokenRefreshRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/TokenRefreshRequest'
        required: true
      security:
      - Bearer: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/TokenRefresh'
          description: ''
  /api/products/categories/:
    get:
      operationId: products_categories_list
      description: Get all product categories for current tenant
      summary: List categories
      parameters:
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      tags:
      - Categories
      security:
      - jwtAuth: []
      - Bearer: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedCategoryList'
          description: ''
    post:
      operationId: products_categories_create
      description: Create a new product category
      summary: Create category
      tags:
      - Categories
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/CategoryRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/CategoryRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/CategoryRequest'
        required: true
      security:
      - jwtAuth: []
      - Bearer: []
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Category'
          description: ''
  /api/products/categories/{id}/:
    get:
      operationId: products_categories_retrieve
      description: Product category management
      summary: Get category details
      parameters:
      - in: path
        name: id
        schema:
          type: string
        required: true
      tags:
      - Categories
      security:
      - jwtAuth: []
      - Bearer: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Category'
          description: ''
    put:
      operationId: products_categories_update
      description: Product category management
      summary: Update category
      parameters:
      - in: path
        name: id
        schema:
          type: string
        required: true
      tags:
      - Categories
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/CategoryRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/CategoryRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/CategoryRequest'
        required: true
      security:
      - jwtAuth: []
      - Bearer: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Category'
          description: ''
    patch:
      operationId: products_categories_partial_update
      description: Product category management
      parameters:
      - in: path
        name: id
        schema:
          type: string
        required: true
      tags:
      - Categories
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedCategoryRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PatchedCategoryRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PatchedCategoryRequest'
      security:
      - jwtAuth: []
      - Bearer: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Category'
          description: ''
    delete:
      operationId: products_categories_destroy
      description: Product category management
      summary: Delete category
      parameters:
      - in: path
        name: id
        schema:
          type: string
        required: true
      tags:
      - Categories
      security:
      - jwtAuth: []
      - Bearer: []
      responses:
        '204':
          description: No response body
  /api/products/products/:
    get:
      operationId: products_products_list
      description: Get all products for current tenant with filtering and search
      summary: List products
      parameters:
      - in: query
        name: category
        schema:
          type: integer
        description: Filter by category ID
      - in: query
        name: is_active
        schema:
          type: boolean
        description: Filter active products
      - in: query
        name: is_featured
        schema:
          type: boolean
        description: Filter featured products
      - in: query
        name: ordering
        schema:
          type: string
        description: 'Order by: price, -price, created_at, -created_at, name, -name'
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      - in: query
        name: search
        schema:
          type: string
        description: Search in name, description, SKU
      tags:
      - Products
      security:
      - jwtAuth: []
      - Bearer: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedProductList'
          description: ''
    post:
      operationId: products_products_create
      description: Create a new product with dynamic attributes
      summary: Create product
      tags:
      - Products
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/ProductRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/ProductRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/ProductRequest'
        required: true
      security:
      - jwtAuth: []
      - Bearer: []
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Product'
          description: ''
  /api/products/products/{id}/:
    get:
      operationId: products_products_retrieve
      description: Retrieve detailed product information
      summary: Get product details
      parameters:
      - in: path
        name: id
        schema:
          type: string
        required: true
      tags:
      - Products
      security:
      - jwtAuth: []
      - Bearer: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Product'
          description: ''
    put:
      operationId: products_products_update
      description: Update product information and attributes
      summary: Update product
      parameters:
      - in: path
        name: id
        schema:
          type: string
        required: true
      tags:
      - Products
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/ProductRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/ProductRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/ProductRequest'
        required: true
      security:
      - jwtAuth: []
      - Bearer: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Product'
          description: ''
    patch:
      operationId: products_products_partial_update
      description: |-
        Product Management API (Tenant-Aware)

        Supports dynamic product attributes via JSONField.
      parameters:
      - in: path
        name: id
        schema:
          type: string
        required: true
      tags:
      - Products
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedProductRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PatchedProductRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PatchedProductRequest'
      security:
      - jwtAuth: []
      - Bearer: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Product'
          description: ''
    delete:
      operationId: products_products_destroy
      description: Permanently delete a product
      summary: Delete product
      parameters:
      - in: path
        name: id
        schema:
          type: string
        required: true
      tags:
      - Products
      security:
      - jwtAuth: []
      - Bearer: []
      responses:
        '204':
          description: No response body
  /api/products/products/{id}/toggle_featured/:
    post:
      operationId: products_products_toggle_featured_create
      description: Mark or unmark product as featured
      summary: Toggle product featured status
      parameters:
      - in: path
        name: id
        schema:
          type: string
        required: true
      tags:
      - Products
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/ProductRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/ProductRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/ProductRequest'
        required: true
      security:
      - jwtAuth: []
      - Bearer: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Product'
          description: ''
  /api/products/products/featured/:
    get:
      operationId: products_products_featured_retrieve
      description: Returns all featured and active products
      summary: Get featured products
      tags:
      - Products
      security:
      - jwtAuth: []
      - Bearer: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Product'
          description: ''
  /api/tenant/info/:
    get:
      operationId: tenant_info_retrieve
      description: Returns current tenant/store information based on subdomain
      summary: Get tenant info
      tags:
      - Stores
      security:
      - jwtAuth: []
      - Bearer: []
      - {}
      responses:
        '200':
          description: No response body
  /api/tenant/stores/:
    get:
      operationId: tenant_stores_list
      description: Get all stores owned by the authenticated user
      summary: List user's stores
      parameters:
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      tags:
      - Stores
      security:
      - jwtAuth: []
      - Bearer: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedStoreList'
          description: ''
    post:
      operationId: tenant_stores_create
      description: Create a new store/tenant. Subdomain must be unique.
      summary: Create new store
      tags:
      - Stores
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/StoreCreateRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/StoreCreateRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/StoreCreateRequest'
        required: true
      security:
      - jwtAuth: []
      - Bearer: []
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/StoreCreate'
          description: ''
  /api/tenant/stores/{id}/:
    get:
      operationId: tenant_stores_retrieve
      description: Retrieve detailed information about a specific store
      summary: Get store details
      parameters:
      - in: path
        name: id
        schema:
          type: string
        required: true
      tags:
      - Stores
      security:
      - jwtAuth: []
      - Bearer: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Store'
          description: ''
    put:
      operationId: tenant_stores_update
      description: Update store information
      summary: Update store
      parameters:
      - in: path
        name: id
        schema:
          type: string
        required: true
      tags:
      - Stores
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/StoreRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/StoreRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/StoreRequest'
        required: true
      security:
      - jwtAuth: []
      - Bearer: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Store'
          description: ''
    patch:
      operationId: tenant_stores_partial_update
      description: Multi-tenant store management
      parameters:
      - in: path
        name: id
        schema:
          type: string
        required: true
      tags:
      - Stores
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedStoreRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PatchedStoreRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PatchedStoreRequest'
      security:
      - jwtAuth: []
      - Bearer: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Store'
          description: ''
    delete:
      operationId: tenant_stores_destroy
      description: Permanently delete a store and all associated data
      summary: Delete store
      parameters:
      - in: path
        name: id
        schema:
          type: string
        required: true
      tags:
      - Stores
      security:
      - jwtAuth: []
      - Bearer: []
      responses:
        '204':
          description: No response body
  /api/tenant/stores/{id}/toggle_active/:
    post:
      operationId: tenant_stores_toggle_active_create
      description: Enable or disable a store
      summary: Toggle store active status
      parameters:
      - in: path
        name: id
        schema:
          type: string
        required: true
      tags:
      - Stores
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/StoreRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/StoreRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/StoreRequest'
        required: true
      security:
      - jwtAuth: []
      - Bearer: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Store'
          description: ''
  /api/tenant/stores/my_stores/:
    get:
      operationId: tenant_stores_my_stores_retrieve
      description: Get all stores owned by current user with count
      summary: Get my stores
      tags:
      - Stores
      security:
      - jwtAuth: []
      - Bearer: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Store'
          description: ''
components:
  schemas:
    Category:
      type: object
      description: Category Serializer
      properties:
        id:
          type: integer
          readOnly: true
        name:
          type: string
          maxLength: 100
        slug:
          type: string
          maxLength: 100
          pattern: ^[-a-zA-Z0-9_]+$
        description:
          type: string
        parent:
          type: integer
          nullable: true
        product_count:
          type: string
          readOnly: true
        created_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - created_at
      - id
      - name
      - product_count
      - slug
    CategoryRequest:
      type: object
      description: Category Serializer
      properties:
        name:
          type: string
          minLength: 1
          maxLength: 100
        slug:
          type: string
          minLength: 1
          maxLength: 100
          pattern: ^[-a-zA-Z0-9_]+$
        description:
          type: string
        parent:
          type: integer
          nullable: true
      required:
      - name
      - slug
    CurrencyEnum:
      enum:
      - USD
      - EUR
      - GBP
      - INR
      type: string
      description: |-
        * `USD` - US Dollar
        * `EUR` - Euro
        * `GBP` - British Pound
        * `INR` - Indian Rupee
    PaginatedCategoryList:
      type: object
      properties:
        count:
          type: integer
          example: 123
        next:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?page=4
        previous:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?page=2
        results:
          type: array
          items:
            $ref: '#/components/schemas/Category'
    PaginatedProductList:
      type: object
      properties:
        count:
          type: integer
          example: 123
        next:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?page=4
        previous:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?page=2
        results:
          type: array
          items:
            $ref: '#/components/schemas/Product'
    PaginatedStoreList:
      type: object
      properties:
        count:
          type: integer
          example: 123
        next:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?page=4
        previous:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?page=2
        results:
          type: array
          items:
            $ref: '#/components/schemas/Store'
    PatchedCategoryRequest:
      type: object
      description: Category Serializer
      properties:
        name:
          type: string
          minLength: 1
          maxLength: 100
        slug:
          type: string
          minLength: 1
          maxLength: 100
          pattern: ^[-a-zA-Z0-9_]+$
        description:
          type: string
        parent:
          type: integer
          nullable: true
    PatchedProductRequest:
      type: object
      description: |-
        Product Serializer with Dynamic Attributes

        USAGE:
        {
            "name": "Samsung Galaxy S24",
            "slug": "samsung-galaxy-s24",
            "description": "Latest flagship phone",
            "price": "999.99",
            "compare_at_price": "1199.99",
            "sku": "SAMS24-256-BLACK",
            "stock_quantity": 50,
            "category": 1,
            "attributes": {
                "brand": "Samsung",
                "storage": "256GB",
                "color": "Phantom Black",
                "screen_size": "6.2 inches",
                "camera": "50MP"
            }
        }
      properties:
        name:
          type: string
          minLength: 1
          maxLength: 200
        slug:
          type: string
          minLength: 1
          maxLength: 200
          pattern: ^[-a-zA-Z0-9_]+$
        description:
          type: string
          minLength: 1
        price:
          type: string
          format: decimal
          pattern: ^-?\d{0,8}(?:\.\d{0,2})?$
        compare_at_price:
          type: string
          format: decimal
          pattern: ^-?\d{0,8}(?:\.\d{0,2})?$
          nullable: true
          description: Original price (for showing discounts)
        sku:
          type: string
          minLength: 1
          maxLength: 100
        stock_quantity:
          type: integer
          maximum: 2147483647
          minimum: 0
        category:
          type: integer
          nullable: true
        attributes:
          description: Store-specific product attributes (size, color, etc.)
        is_active:
          type: boolean
        is_featured:
          type: boolean
    PatchedStoreRequest:
      type: object
      description: Store Serializer - Full store details
      properties:
        name:
          type: string
          minLength: 1
          description: Store display name (e.g., "Nike Official Store")
          maxLength: 100
        subdomain:
          type: string
          minLength: 1
          description: Unique subdomain (e.g., "nike" for nike.myplatform.com)
          pattern: ^[a-z0-9-]+$
          maxLength: 50
        description:
          type: string
        logo:
          type: string
          format: binary
          nullable: true
        currency:
          $ref: '#/components/schemas/CurrencyEnum'
        is_active:
          type: boolean
          description: Inactive stores are inaccessible to customers
    Product:
      type: object
      description: |-
        Product Serializer with Dynamic Attributes

        USAGE:
        {
            "name": "Samsung Galaxy S24",
            "slug": "samsung-galaxy-s24",
            "description": "Latest flagship phone",
            "price": "999.99",
            "compare_at_price": "1199.99",
            "sku": "SAMS24-256-BLACK",
            "stock_quantity": 50,
            "category": 1,
            "attributes": {
                "brand": "Samsung",
                "storage": "256GB",
                "color": "Phantom Black",
                "screen_size": "6.2 inches",
                "camera": "50MP"
            }
        }
      properties:
        id:
          type: integer
          readOnly: true
        name:
          type: string
          maxLength: 200
        slug:
          type: string
          maxLength: 200
          pattern: ^[-a-zA-Z0-9_]+$
        description:
          type: string
        price:
          type: string
          format: decimal
          pattern: ^-?\d{0,8}(?:\.\d{0,2})?$
        compare_at_price:
          type: string
          format: decimal
          pattern: ^-?\d{0,8}(?:\.\d{0,2})?$
          nullable: true
          description: Original price (for showing discounts)
        sku:
          type: string
          maxLength: 100
        stock_quantity:
          type: integer
          maximum: 2147483647
          minimum: 0
        category:
          type: integer
          nullable: true
        category_name:
          type: string
          readOnly: true
        attributes:
          description: Store-specific product attributes (size, color, etc.)
        is_active:
          type: boolean
        is_featured:
          type: boolean
        is_on_sale:
          type: boolean
          readOnly: true
        discount_percentage:
          type: integer
          readOnly: true
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - category_name
      - created_at
      - description
      - discount_percentage
      - id
      - is_on_sale
      - name
      - price
      - sku
      - slug
      - updated_at
    ProductRequest:
      type: object
      description: |-
        Product Serializer with Dynamic Attributes

        USAGE:
        {
            "name": "Samsung Galaxy S24",
            "slug": "samsung-galaxy-s24",
            "description": "Latest flagship phone",
            "price": "999.99",
            "compare_at_price": "1199.99",
            "sku": "SAMS24-256-BLACK",
            "stock_quantity": 50,
            "category": 1,
            "attributes": {
                "brand": "Samsung",
                "storage": "256GB",
                "color": "Phantom Black",
                "screen_size": "6.2 inches",
                "camera": "50MP"
            }
        }
      properties:
        name:
          type: string
          minLength: 1
          maxLength: 200
        slug:
          type: string
          minLength: 1
          maxLength: 200
          pattern: ^[-a-zA-Z0-9_]+$
        description:
          type: string
          minLength: 1
        price:
          type: string
          format: decimal
          pattern: ^-?\d{0,8}(?:\.\d{0,2})?$
        compare_at_price:
          type: string
          format: decimal
          pattern: ^-?\d{0,8}(?:\.\d{0,2})?$
          nullable: true
          description: Original price (for showing discounts)
        sku:
          type: string
          minLength: 1
          maxLength: 100
        stock_quantity:
          type: integer
          maximum: 2147483647
          minimum: 0
        category:
          type: integer
          nullable: true
        attributes:
          description: Store-specific product attributes (size, color, etc.)
        is_active:
          type: boolean
        is_featured:
          type: boolean
      required:
      - description
      - name
      - price
      - sku
      - slug
    Store:
      type: object
      description: Store Serializer - Full store details
      properties:
        id:
          type: integer
          readOnly: true
        name:
          type: string
          description: Store display name (e.g., "Nike Official Store")
          maxLength: 100
        subdomain:
          type: string
          description: Unique subdomain (e.g., "nike" for nike.myplatform.com)
          pattern: ^[a-z0-9-]+$
          maxLength: 50
        description:
          type: string
        logo:
          type: string
          format: uri
          nullable: true
        currency:
          $ref: '#/components/schemas/CurrencyEnum'
        is_active:
          type: boolean
          description: Inactive stores are inaccessible to customers
        owner:
          type: integer
          readOnly: true
          description: User who created/owns this store
        owner_email:
          type: string
          format: email
          readOnly: true
        full_domain:
          type: string
          readOnly: true
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - created_at
      - full_domain
      - id
      - name
      - owner
      - owner_email
      - subdomain
      - updated_at
    StoreCreate:
      type: object
      description: Store Creation Serializer - Used when creating new stores
      properties:
        name:
          type: string
          description: Store display name (e.g., "Nike Official Store")
          maxLength: 100
        subdomain:
          type: string
          description: Unique subdomain (e.g., "nike" for nike.myplatform.com)
          pattern: ^[a-z0-9-]+$
          maxLength: 50
        description:
          type: string
        currency:
          $ref: '#/components/schemas/CurrencyEnum'
      required:
      - name
      - subdomain
    StoreCreateRequest:
      type: object
      description: Store Creation Serializer - Used when creating new stores
      properties:
        name:
          type: string
          minLength: 1
          description: Store display name (e.g., "Nike Official Store")
          maxLength: 100
        subdomain:
          type: string
          minLength: 1
          description: Unique subdomain (e.g., "nike" for nike.myplatform.com)
          pattern: ^[a-z0-9-]+$
          maxLength: 50
        description:
          type: string
        currency:
          $ref: '#/components/schemas/CurrencyEnum'
      required:
      - name
      - subdomain
    StoreRequest:
      type: object
      description: Store Serializer - Full store details
      properties:
        name:
          type: string
          minLength: 1
          description: Store display name (e.g., "Nike Official Store")
          maxLength: 100
        subdomain:
          type: string
          minLength: 1
          description: Unique subdomain (e.g., "nike" for nike.myplatform.com)
          pattern: ^[a-z0-9-]+$
          maxLength: 50
        description:
          type: string
        logo:
          type: string
          format: binary
          nullable: true
        currency:
          $ref: '#/components/schemas/CurrencyEnum'
        is_active:
          type: boolean
          description: Inactive stores are inaccessible to customers
      required:
      - name
      - subdomain
    TokenRefresh:
      type: object
      properties:
        access:
          type: string
          readOnly: true
        refresh:
          type: string
      required:
      - access
      - refresh
    TokenRefreshRequest:
      type: object
      properties:
        refresh:
          type: string
          minLength: 1
      required:
      - refresh
    UserRegistration:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        email:
          type: string
          format: email
          maxLength: 254
        username:
          type: string
          description: Required. 150 characters or fewer. Letters, digits and @/./+/-/_
            only.
          pattern: ^[\w.@+-]+$
          maxLength: 150
        first_name:
          type: string
          maxLength: 150
        last_name:
          type: string
          maxLength: 150
        phone:
          type: string
          nullable: true
          maxLength: 15
        is_store_owner:
          type: boolean
          description: Designates whether user can create/manage stores
      required:
      - email
      - id
      - username
    UserRegistrationRequest:
      type: object
      properties:
        email:
          type: string
          format: email
          minLength: 1
          maxLength: 254
        username:
          type: string
          minLength: 1
          description: Required. 150 characters or fewer. Letters, digits and @/./+/-/_
            only.
          pattern: ^[\w.@+-]+$
          maxLength: 150
        password:
          type: string
          writeOnly: true
          minLength: 1
        password2:
          type: string
          writeOnly: true
          minLength: 1
          title: Confirm Password
        first_name:
          type: string
          maxLength: 150
        last_name:
          type: string
          maxLength: 150
        phone:
          type: string
          nullable: true
          maxLength: 15
        is_store_owner:
          type: boolean
          description: Designates whether user can create/manage stores
      required:
      - email
      - password
      - password2
      - username
  securitySchemes:
    Bearer:
      type: http
      scheme: bearer
      bearerFormat: JWT
    jwtAuth:
      type: http
      scheme: bearer
      bearerFormat: JWT

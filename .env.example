# ============================================
# Environment Variables
# Copy this to .env: cp .env.example .env
# ============================================

# Django
SECRET_KEY=dev-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.localhost,backend

# Database (must match postgres service in docker-compose.yml)
DB_NAME=ecommerce_multitenancy
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=postgres
DB_PORT=5432

# Redis (must match redis service in docker-compose.yml)
REDIS_HOST=redis
REDIS_PORT=6379

# JWT
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# Frontend URL
FRONTEND_URL=http://localhost:3000

# ============================================
# PRODUCTION — override these in your .env
# ============================================
# SECRET_KEY=<generate-a-random-50-char-string>
# DEBUG=False
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# DB_PASSWORD=<strong-password>
# FRONTEND_URL=https://yourdomain.com
# CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# DOMAIN=yourdomain.com
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

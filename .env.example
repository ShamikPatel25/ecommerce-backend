# ============================================
# Local Development Environment Variables
# Copy this to .env: cp .env.example .env
# ============================================

# Django
SECRET_KEY=dev-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.localhost,backend

# Database (must match postgres service in docker-compose.yml)
DB_NAME=ecommerce_multitenancy
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=postgres
DB_PORT=5432

# Redis (must match redis service in docker-compose.yml)
REDIS_HOST=redis
REDIS_PORT=6379

# JWT
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# Frontend URL
FRONTEND_URL=http://localhost:3000
